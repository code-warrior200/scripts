{
  "name": "rampart-power-agri-saas",
  "version": "1.0.0",
  "description": "Rampart Power - Agricultural SaaS Platform for farm management",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^3.6.0",
    "next": "14.2.5",
    "next-auth": "^4.24.14",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-icons": "^5.6.0",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "20.14.2",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.21.0",
    "typescript": "5.6.2"
  }
}
