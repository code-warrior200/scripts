// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// MULTI-TENANCY: Organization model for SaaS
// ============================================
model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        String   @default("free") // free, pro, enterprise
  status      String   @default("active") // active, suspended, cancelled
  maxUsers    Int      @default(1)
  maxFarms    Int      @default(3)
  features    Json     @default("{\"analytics\":false,\"apiAccess\":false,\"multiUser\":false}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  farms       Farm[]
  crops       Crop[]
  subscriptions Subscription[]
  invitations OrganizationInvitation[]
}

// ============================================
// USER & AUTHENTICATION
// ============================================
enum UserRole {
  ADMIN       // Full platform access (organization owner)
  FARM_MANAGER // Manage farm operations
  STAFF       // Operational input only
  VIEWER      // Read-only access
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String?
  name            String
  image           String?
  role            UserRole  @default(VIEWER)
  emailVerified   DateTime?
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  farms           Farm[]
  subscriptions   Subscription[]
  notifications   Notification[]
  accounts        Account[]
  sessions        Session[]
  assignedTasks   Task[]         @relation("AssignedTasks")
  createdTasks    Task[]         @relation("CreatedTasks")
  assignedActivities Activity[]   @relation("AssignedActivities")
  createdActivities  Activity[]   @relation("CreatedActivities")
  pestReports     PestReport[]
  attendance      Attendance[]
  activityLogs    ActivityLog[]
  inventoryLogs   InventoryLog[]
}

// OAuth Account model (for Google, GitHub, etc.)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Session model for NextAuth
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Verification Token model for NextAuth
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Organization Invitation for team collaboration
model OrganizationInvitation {
  id             String   @id @default(cuid())
  email          String
  role           UserRole @default(VIEWER)
  token          String   @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  invitedById    String
  expiresAt      DateTime
  status         String   @default("pending") // pending, accepted, expired, cancelled
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([token])
}

// ============================================
// FARM MANAGEMENT
// ============================================
model Farm {
  id             String   @id @default(cuid())
  name           String
  description    String?
  region         String
  address        String?
  gpsCoordinates Json?    // { lat: number, lng: number }
  totalArea      Float?   // in hectares
  areaUnit       String   @default("hectares")
  soilType       String?
  irrigationType String?  // drip, sprinkler, flood, none
  status         String   @default("active") // active, inactive, archived
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  fields         Field[]
  crops          Crop[]
  inventories    Inventory[]
  equipment      Equipment[]
  weatherLogs    WeatherLog[]

  @@index([organizationId])
  @@index([ownerId])
}

// Field/Plot management within a farm
model Field {
  id             String   @id @default(cuid())
  name           String
  area           Float?   // in hectares
  areaUnit       String   @default("hectares")
  soilType       String?
  gpsBoundaries  Json?    // { type: "Polygon", coordinates: [...] }
  irrigationStatus Boolean @default(false)
  status         String   @default("available") // available, planted, fallow, maintenance
  farmId         String
  farm           Farm     @relation(fields: [farmId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  cropCycles     CropCycle[]
  activities     Activity[]

  @@index([farmId])
}

// ============================================
// CROP LIFECYCLE TRACKING
// ============================================
enum GrowthStage {
  PLANNING
  PLANTED
  GERMINATION
  VEGETATIVE
  FLOWERING
  FRUITING
  MATURING
  HARVEST_READY
  HARVESTED
  POST_HARVEST
}

model Crop {
  id             String   @id @default(cuid())
  name           String   // e.g., "Corn", "Wheat"
  variety        String?  // e.g., "Sweet Corn", "Hard Red Winter"
  category       String?  // e.g., "Grain", "Vegetable", "Fruit"
  description    String?
  imageUrl       String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  cropCycles     CropCycle[]
  farmCrops      Farm[]

  @@index([organizationId])
}

// Crop Cycle - tracks a specific planting of a crop
model CropCycle {
  id             String      @id @default(cuid())
  name           String      // e.g., "2024 Spring Corn"
  cropId         String
  crop           Crop        @relation(fields: [cropId], references: [id])
  fieldId        String
  field          Field       @relation(fields: [fieldId], references: [id])
  plantingDate   DateTime?
  expectedHarvestDate DateTime?
  actualHarvestDate   DateTime?
  growthStage    GrowthStage @default(PLANNING)
  estimatedYield Float?      // in tons
  actualYield    Float?      // in tons
  yieldUnit      String      @default("tons")
  status         String      @default("planned") // planned, active, completed, failed
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  activities     Activity[]
  harvestLogs    HarvestLog[]
  pestReports    PestReport[]

  @@index([cropId])
  @@index([fieldId])
}

// Activity Log for crop lifecycle tracking
model Activity {
  id             String   @id @default(cuid())
  type           String   // planting, fertilizing, irrigation, pest_control, weeding, pruning, harvesting
  title          String
  description    String?
  scheduledDate  DateTime?
  completedDate  DateTime?
  status         String   @default("pending") // pending, in_progress, completed, cancelled
  data           Json?    // { fertilizerType: "...", amount: "...", etc. }
  fieldId        String
  field          Field    @relation(fields: [fieldId], references: [id])
  cropCycleId    String?
  cropCycle      CropCycle? @relation(fields: [cropCycleId], references: [id])
  assignedToId   String?
  assignedTo     User?    @relation("AssignedActivities", fields: [assignedToId], references: [id])
  createdById    String
  createdBy      User     @relation("CreatedActivities", fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([fieldId])
  @@index([cropCycleId])
  @@index([assignedToId])
}

// Pest/Disease Reporting
model PestReport {
  id             String   @id @default(cuid())
  pestType       String   // pest, disease, weed
  name           String
  severity       String   @default("low") // low, medium, high, critical
  description    String?
  affectedArea   Float?   // in hectares
  imageUrl       String?
  cropCycleId    String
  cropCycle      CropCycle @relation(fields: [cropCycleId], references: [id])
  reportedById   String
  reportedBy     User     @relation(fields: [reportedById], references: [id])
  status         String   @default("open") // open, treated, resolved
  treatment      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([cropCycleId])
  @@index([reportedById])
}

// Harvest Log
model HarvestLog {
  id             String   @id @default(cuid())
  cropCycleId    String
  cropCycle      CropCycle @relation(fields: [cropCycleId], references: [id])
  harvestDate    DateTime
  quantity       Float    // harvested amount
  unit           String   @default("kg")
  quality        String?  // Grade A, B, C, etc.
  notes          String?
  createdBy      String
  createdAt      DateTime @default(now())

  @@index([cropCycleId])
}

// ============================================
// INVENTORY & RESOURCE MANAGEMENT
// ============================================
enum InventoryType {
  SEED
  FERTILIZER
  PESTICIDE
  HERBICIDE
  EQUIPMENT
  TOOL
  FUEL
  OTHER
}

model Inventory {
  id             String        @id @default(cuid())
  name           String
  type           InventoryType @default(OTHER)
  category       String?
  quantity       Float         @default(0)
  unit           String        @default("kg") // kg, liters, units, etc.
  minQuantity    Float?        // reorder threshold
  maxQuantity    Float?
  unitPrice      Float?
  totalValue     Float?
  supplier       String?
  expiryDate     DateTime?
  storageLocation String?
  farmId         String
  farm           Farm          @relation(fields: [farmId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  inventoryLogs  InventoryLog[]

  @@index([farmId])
}

// Inventory transaction log
model InventoryLog {
  id             String   @id @default(cuid())
  inventoryId    String
  inventory      Inventory @relation(fields: [inventoryId], references: [id])
  type           String   @default("adjustment") // purchase, usage, adjustment, transfer
  quantity       Float    // positive for addition, negative for deduction
  unit           String
  reference      String?  // reference number or note
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())

  @@index([inventoryId])
  @@index([userId])
}

// Equipment tracking
model Equipment {
  id             String   @id @default(cuid())
  name           String
  type           String   // tractor, harvester, irrigator, etc.
  model          String?
  serialNumber   String?
  purchaseDate   DateTime?
  purchasePrice  Float?
  status         String   @default("available") // available, in_use, maintenance, broken
  condition      String   @default("good") // new, good, fair, poor
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  farmId         String
  farm           Farm     @relation(fields: [farmId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([farmId])
}

// ============================================
// TASK & WORKFORCE MANAGEMENT
// ============================================
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Task {
  id             String        @id @default(cuid())
  title          String
  description    String?
  priority       TaskPriority  @default(MEDIUM)
  status         TaskStatus    @default(PENDING)
  dueDate        DateTime?
  completedDate  DateTime?
  estimatedHours Float?
  actualHours    Float?
  type           String?       // field_work, maintenance, harvesting, etc.
  farmId         String?
  fieldId        String?
  cropCycleId    String?
  assignedToId   String?
  assignedTo     User?         @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdById    String
  createdBy      User          @relation("CreatedTasks", fields: [createdById], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([assignedToId])
  @@index([createdById])
  @@index([farmId])
}

// Attendance logging
model Attendance {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  date           DateTime
  checkIn        DateTime?
  checkOut       DateTime?
  status         String   @default("present") // present, absent, late, half_day, leave
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@unique([userId, date])
}

// ============================================
// ANALYTICS & REPORTING
// ============================================
model ActivityLog {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  action         String   // create, update, delete, login, etc.
  resource       String?  // farm, crop, task, etc.
  resourceId     String?
  details        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Weather data logging
model WeatherLog {
  id             String   @id @default(cuid())
  farmId         String
  farm           Farm     @relation(fields: [farmId], references: [id])
  temperature    Float?   // Celsius
  humidity       Float?   // percentage
  rainfall       Float?   // mm
  windSpeed      Float?   // km/h
  conditions     String?  // sunny, cloudy, rainy, etc.
  recordedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([farmId])
}

// ============================================
// NOTIFICATIONS & ALERTS
// ============================================
enum NotificationType {
  WEATHER
  INVENTORY
  TASK
  PEST
  HARVEST
  SYSTEM
  ALERT
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  priority  String   @default("normal") // low, normal, high, urgent
  read      Boolean  @default(false)
  actionUrl String?
  metadata  Json?    // additional data for the notification
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============================================
// SUBSCRIPTION & BILLING
// ============================================
model Subscription {
  id              String    @id @default(cuid())
  plan            String    @default("free") // free, pro, enterprise
  status          String    @default("active") // active, cancelled, past_due
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  amount          Float?
  currency        String    @default("USD")
  paymentMethod   String?   // card, bank_transfer, etc.
  stripeCustomerId String?
  stripeSubscriptionId String?
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([organizationId])
}
